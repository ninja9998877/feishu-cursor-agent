# 飞书应用凭证（开发者后台 → 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx

# 默认工作目录（Cursor Agent 在此目录下执行）
DEFAULT_WORKDIR=D:/Project/zombie_dev

# 本机 Cursor CLI：在 PowerShell 里执行 `where.exe agent` 确认已在 PATH 中
CURSOR_AGENT_CMD=agent

# 可选：附加参数，例如 --model gpt-5.2（多个参数用空格，勿加引号）
CURSOR_AGENT_EXTRA_ARGS=

# 可选：自动加在每条指令前的系统前缀（例如强调工程与规范）
CURSOR_AGENT_PROMPT_PREFIX=

# 单条任务超时（秒）
AGENT_TIMEOUT_SEC=3600

# 群聊里是否必须 @ 机器人才响应（推荐 true）
FEISHU_REQUIRE_GROUP_MENTION=true

# 若上一项为 true：填机器人的 open_id（开发者后台 → 机器人 → 机器人信息，或抓一条 @ 消息看 mentions）
FEISHU_BOT_OPEN_ID=

# 可选：白名单 chat_id，逗号分隔；留空表示不限制会话
ALLOWED_CHAT_IDS=

# 可选：白名单发送者 open_id，逗号分隔；留空表示不限制用户
ALLOWED_SENDER_OPEN_IDS=

# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
